# Copy to secret.yaml (gitignored) or create via kubectl:
#
# kubectl create secret generic job-search-web-secrets \
#   --namespace=job-search \
#   --from-literal=AUTH0_DOMAIN='...' \
#   --from-literal=AUTH0_CLIENT_ID='...' \
#   --from-literal=AUTH0_CLIENT_SECRET='...' \
#   --from-literal=AUTH0_SECRET='...'
#
apiVersion: v1
kind: Secret
metadata:
  name: job-search-web-secrets
  namespace: job-search
type: Opaque
stringData:
  AUTH0_DOMAIN: "<auth0-domain>"
  AUTH0_CLIENT_ID: "<auth0-client-id>"
  AUTH0_CLIENT_SECRET: "<auth0-client-secret>"
  AUTH0_SECRET: "<auth0-secret>"
